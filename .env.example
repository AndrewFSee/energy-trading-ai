# Environment Variables — Copy to .env and fill in your keys
# Never commit your actual .env file to version control

# EIA (Energy Information Administration) API
# Get your key at: https://www.eia.gov/opendata/register.php
EIA_API_KEY=your_eia_api_key_here

# FRED (Federal Reserve Economic Data) API
# Get your key at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# NewsAPI for news headlines
# Get your key at: https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here

# OpenAI API (optional — for GPT-4o LLM; leave blank to use local Ollama)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# NOAA Climate Data Online API
# Get your key at: https://www.ncdc.noaa.gov/cdo-web/token
NOAA_API_KEY=your_noaa_api_key_here

# Optional: Ollama base URL (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# Optional: ChromaDB host (default: localhost)
CHROMADB_HOST=localhost
CHROMADB_PORT=8000
